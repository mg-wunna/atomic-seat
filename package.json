{
  "name": "atomic-seat",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "lefthook install",
    "dev": "(cd apps/server && bun run dev) & (cd apps/website && bun run dev) & (cd apps/dashboard && bun run dev)",
    "dev:server": "cd apps/server && bun run dev",
    "dev:website": "cd apps/website && bun run dev",
    "dev:dashboard": "cd apps/dashboard && bun run dev",
    "build": "cd apps/server && bun run build && cd ../website && bun run build && cd ../dashboard && bun run build",
    "build:server": "cd apps/server && bun run build",
    "build:website": "cd apps/website && bun run build",
    "build:dashboard": "cd apps/dashboard && bun run build",
    "start:server": "cd apps/server && bun run start",
    "test": "cd apps/server && bun run test",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report playwright-report",
    "check:bundle": "bun scripts/check-bundle-size.ts",
    "seed": "cd apps/server && bun run seed",
    "deploy:staging": "gh workflow run staging-deploy.yml --ref main && gh run watch",
    "typecheck": "cd packages/configs && bun run typecheck && cd ../api && bun run typecheck && cd ../../apps/server && bun run typecheck && cd ../website && bun run typecheck && cd ../dashboard && bun run typecheck",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@playwright/test": "^1.59.1",
    "@types/bun": "^1.3.11",
    "@types/node": "^22.13.14",
    "lefthook": "^2.1.4",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.10"
}
