{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=../../.env.development --watch --import tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=../../.env.production dist/index.js",
    "seed": "node --env-file=../../.env.development --import tsx src/seed.ts",
    "test": "node --env-file=../../.env.development --import tsx test/ticketing.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@orpc/contract": "^1.12.2",
    "@orpc/openapi": "^1.12.2",
    "@orpc/server": "^1.12.2",
    "@template/api": "workspace:*",
    "@template/configs": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "hono": "^4.8.2",
    "hono-rate-limiter": "^0.5.3",
    "reflect-metadata": "^0.2.2",
    "stripe": "^22.1.0",
    "typeorm": "^0.3.28",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
